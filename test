public X509Certificate validateCertificateFromText(String publicCertText) throws Exception {
    log.info("******** validateCertificateFromText BEGIN ********");

    List<X509Certificate> incomingCerts = loadCertificatesFromText(publicCertText);

    if (incomingCerts.isEmpty()) {
        throw new IllegalArgumentException("No certificate found in input text");
    }

    X509Certificate leafCert = incomingCerts.get(0);

    log.info("Incoming certificate count: {}", incomingCerts.size());
    logCert("LEAF", leafCert);

    for (int i = 1; i < incomingCerts.size(); i++) {
        logCert("INCOMING-INTERMEDIATE-" + i, incomingCerts.get(i));
    }

    for (int i = 0; i < rootCerts.size(); i++) {
        X509Certificate root = rootCerts.get(i);
        logCert("ROOT-" + i, root);

        log.info("Leaf issuer matches root subject? {}",
                leafCert.getIssuerX500Principal().equals(root.getSubjectX500Principal()));
    }

    X509CertSelector selector = new X509CertSelector();
    selector.setCertificate(leafCert);

    PKIXBuilderParameters params =
            new PKIXBuilderParameters(trustAnchors, selector);

    params.setRevocationEnabled(false);

    // Important: give PKIX the incoming intermediate certs
    CertStore certStore = CertStore.getInstance(
            "Collection",
            new CollectionCertStoreParameters(incomingCerts)
    );

    params.addCertStore(certStore);

    log.info("Starting PKIX path builder...");

    try {
        CertPathBuilder builder = CertPathBuilder.getInstance("PKIX");
        PKIXCertPathBuilderResult result =
                (PKIXCertPathBuilderResult) builder.build(params);

        log.info("PKIX validation successful");
        log.info("Trust anchor used: {}",
                result.getTrustAnchor().getTrustedCert().getSubjectX500Principal());

        return leafCert;

    } catch (CertPathBuilderException ex) {
        log.error("PKIX path build failed: {}", ex.getMessage());
        log.error("Leaf Subject: {}", leafCert.getSubjectX500Principal());
        log.error("Leaf Issuer : {}", leafCert.getIssuerX500Principal());
        log.error("Root cert count: {}", rootCerts.size());
        log.error("TrustAnchor count: {}", trustAnchors.size());

        throw new CertificateException(
                "Certificate chain validation failed. Intermediate certificate may be missing.",
                ex
        );
    }
}




private List<X509Certificate> loadCertificatesFromText(String certText) throws Exception {
    String normalized = normalizeCertificates(certText);

    CertificateFactory cf = CertificateFactory.getInstance("X.509");

    try (InputStream is = new ByteArrayInputStream(normalized.getBytes(StandardCharsets.UTF_8))) {
        Collection<? extends Certificate> certs = cf.generateCertificates(is);

        List<X509Certificate> x509Certs = new ArrayList<>();

        for (Certificate cert : certs) {
            x509Certs.add((X509Certificate) cert);
        }

        return x509Certs;
    }
}

private String normalizeCertificates(String certText) {
    String text = certText.trim();

    if (text.contains("-----BEGIN CERTIFICATE-----")) {
        return text;
    }

    String cleaned = text
            .replaceAll("\\s+", "");

    StringBuilder pem = new StringBuilder();
    pem.append("-----BEGIN CERTIFICATE-----\n");

    for (int i = 0; i < cleaned.length(); i += 64) {
        pem.append(cleaned, i, Math.min(i + 64, cleaned.length()))
                .append("\n");
    }

    pem.append("-----END CERTIFICATE-----\n");

    return pem.toString();
}
