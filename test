import static org.mockito.Mockito.*;

@ExtendWith(MockitoExtension.class)
class CertificateSpecificationTest {

    @Test
    void shouldBuildExpiredCertificatePredicate_whenDaysIsZero() {
        CertSearchRequest req = new CertSearchRequest();
        req.setNumDaysToexpire(0);

        Root<Certificate> root = mock(Root.class);
        CriteriaQuery<?> query = mock(CriteriaQuery.class);
        CriteriaBuilder cb = mock(CriteriaBuilder.class);

        Path<LocalDateTime> certEndDatePath = mock(Path.class);
        Predicate expiredPredicate = mock(Predicate.class);
        Predicate finalPredicate = mock(Predicate.class);

        when(root.<LocalDateTime>get("certEndDate")).thenReturn(certEndDatePath);
        when(cb.lessThan(eq(certEndDatePath), any(LocalDateTime.class)))
                .thenReturn(expiredPredicate);
        when(cb.and(any(Predicate[].class))).thenReturn(finalPredicate);

        Predicate result = CertificateSpecification.filter(req)
                .toPredicate(root, query, cb);

        assertNotNull(result);
        assertSame(finalPredicate, result);

        verify(cb).lessThan(eq(certEndDatePath), any(LocalDateTime.class));
        verify(cb).and(any(Predicate[].class));
        verify(cb, never()).greaterThan(any(), any(LocalDateTime.class));
        verify(cb, never()).conjunction();
    }

    @Test
    void shouldBuildExpiringSoonPredicate_whenDaysGreaterThanZero() {
        CertSearchRequest req = new CertSearchRequest();
        req.setNumDaysToexpire(10);

        Root<Certificate> root = mock(Root.class);
        CriteriaQuery<?> query = mock(CriteriaQuery.class);
        CriteriaBuilder cb = mock(CriteriaBuilder.class);

        Path<LocalDateTime> certEndDatePath = mock(Path.class);

        Predicate greaterThanPredicate = mock(Predicate.class);
        Predicate lessThanPredicate = mock(Predicate.class);
        Predicate daysPredicate = mock(Predicate.class);
        Predicate finalPredicate = mock(Predicate.class);

        when(root.<LocalDateTime>get("certEndDate")).thenReturn(certEndDatePath);

        when(cb.greaterThan(eq(certEndDatePath), any(LocalDateTime.class)))
                .thenReturn(greaterThanPredicate);

        when(cb.lessThan(eq(certEndDatePath), any(LocalDateTime.class)))
                .thenReturn(lessThanPredicate);

        when(cb.and(greaterThanPredicate, lessThanPredicate))
                .thenReturn(daysPredicate);

        when(cb.and(any(Predicate[].class)))
                .thenReturn(finalPredicate);

        Predicate result = CertificateSpecification.filter(req)
                .toPredicate(root, query, cb);

        assertNotNull(result);
        assertSame(finalPredicate, result);

        verify(cb).greaterThan(eq(certEndDatePath), any(LocalDateTime.class));
        verify(cb).lessThan(eq(certEndDatePath), any(LocalDateTime.class));
        verify(cb).and(greaterThanPredicate, lessThanPredicate);
        verify(cb).and(any(Predicate[].class));
    }

    @Test
    void shouldReturnConjunctionWhenNoFilters() {
        CertSearchRequest req = new CertSearchRequest();

        Root<Certificate> root = mock(Root.class);
        CriteriaQuery<?> query = mock(CriteriaQuery.class);
        CriteriaBuilder cb = mock(CriteriaBuilder.class);

        Predicate conjunctionPredicate = mock(Predicate.class);

        when(cb.conjunction()).thenReturn(conjunctionPredicate);

        Predicate result = CertificateSpecification.filter(req)
