@ExtendWith(MockitoExtension.class)
class CertificateSpecificationTest {

    @Mock
    Root<Certificate> root;

    @Mock
    CriteriaQuery<?> query;

    @Mock
    CriteriaBuilder cb;

    @Mock
    Path<Object> path;

    @Mock
    Predicate predicate;

    @Test
    void shouldAddCertSerialNumberPredicate() {
        CertSearchRequest req = new CertSearchRequest();
        req.setCertSerialNumber("SER123");

        when(root.get("certSerialNumber")).thenReturn(path);
        when(cb.equal(path, "SER123")).thenReturn(predicate);
        when(cb.and(any(Predicate[].class))).thenReturn(predicate);

        Predicate result = CertificateSpecification.filter(req)
                .toPredicate(root, query, cb);

        assertNotNull(result);
        verify(root).get("certSerialNumber");
        verify(cb).equal(path, "SER123");
    }

    @Test
    void shouldAddKidPredicate() {
        CertSearchRequest req = new CertSearchRequest();
        req.setKid("kid-123");

        when(root.get("jwtId")).thenReturn(path);
        when(cb.equal(path, "kid-123")).thenReturn(predicate);
        when(cb.and(any(Predicate[].class))).thenReturn(predicate);

        Predicate result = CertificateSpecification.filter(req)
                .toPredicate(root, query, cb);

        assertNotNull(result);
        verify(root).get("jwtId");
        verify(cb).equal(path, "kid-123");
    }

    @Test
    void shouldAddAddedByPredicate() {
        CertSearchRequest req = new CertSearchRequest();
        req.setAddedAccount("damu");

        when(root.get("addedBy")).thenReturn(path);
        when(cb.equal(path, "damu")).thenReturn(predicate);
        when(cb.and(any(Predicate[].class))).thenReturn(predicate);

        Predicate result = CertificateSpecification.filter(req)
                .toPredicate(root, query, cb);

        assertNotNull(result);
        verify(root).get("addedBy");
        verify(cb).equal(path, "damu");
    }

    @Test
    void shouldAddJustificationPredicate() {
        CertSearchRequest req = new CertSearchRequest();
        req.setJustification("approved");

        byte[] expectedBytes = "approved".getBytes(StandardCharsets.UTF_8);

        when(root.get("justification")).thenReturn(path);
        when(cb.equal(eq(path), aryEq(expectedBytes))).thenReturn(predicate);
        when(cb.and(any(Predicate[].class))).thenReturn(predicate);

        Predicate result = CertificateSpecification.filter(req)
                .toPredicate(root, query, cb);

        assertNotNull(result);
        verify(root).get("justification");
        verify(cb).equal(eq(path), aryEq(expectedBytes));
    }

    @Test
    void shouldAddNumDaysToExpirePredicate() {
        CertSearchRequest req = new CertSearchRequest();
        req.setNumDaysToExpire(10);

        Path<LocalDateTime> datePath = mock(Path.class);

        when(root.<LocalDateTime>get("certEndDate")).thenReturn(datePath);
        when(cb.greaterThan(eq(datePath), any(LocalDateTime.class))).thenReturn(predicate);
        when(cb.lessThan(eq(datePath), any(LocalDateTime.class))).thenReturn(predicate);
        when(cb.and(any(Predicate.class), any(Predicate.class))).thenReturn(predicate);
        when(cb.and(any(Predicate[].class))).thenReturn(predicate);

        Predicate result = CertificateSpecification.filter(req)
                .toPredicate(root, query, cb);

        assertNotNull(result);
        verify(root, times(2)).get("certEndDate");
        verify(cb).greaterThan(eq(datePath), any(LocalDateTime.class));
        verify(cb).lessThan(eq(datePath), any(LocalDateTime.class));
    }

    @Test
    void shouldReturnConjunctionWhenNoFilters() {
        CertSearchRequest req = new CertSearchRequest();

        when(cb.conjunction()).thenReturn(predicate);

        Predicate result = CertificateSpecification.filter(req)
                .toPredicate(root, query, cb);

        assertNotNull(result);
        verify(cb).conjunction();
        verify(cb, never()).and(any(Predicate[].class));
    }

    @Test
    void shouldApplyMultipleFilters() {
        CertSearchRequest req = new CertSearchRequest();
        req.setCertSerialNumber("SER123");
        req.setKid("kid-123");
        req.setAddedAccount("damu");

        when(root.get(anyString())).thenReturn(path);
        when(cb.equal(any(), any())).thenReturn(predicate);
        when(cb.and(any(Predicate[].class))).thenReturn(predicate);

        Predicate result = CertificateSpecification.filter(req)
                .toPredicate(root, query, cb);

        assertNotNull(result);

        verify(root).get("certSerialNumber");
        verify(root).get("jwtId");
        verify(root).get("addedBy");

        verify(cb).equal(path, "SER123");
        verify(cb).equal(path, "kid-123");
        verify(cb).equal(path, "damu");

        verify(cb).and(any(Predicate[].class));
    }
}
