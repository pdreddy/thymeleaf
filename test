 @Mock
    private CertificateService certificateService;

    @InjectMocks
    private CertificateController certificateController;

    @Test
    void deleteKid_shouldReturnOkWhenDeleted() {
        when(certificateService.deleteCertByClientIdAndKId("client1", "kid1"))
                .thenReturn(true);

        ResponseEntity<?> response =
                certificateController.deleteKID("client1", "kid1");

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertEquals("Kid deleted successfully!", response.getBody());

        verify(certificateService).deleteCertByClientIdAndKId("client1", "kid1");
    }

    @Test
    void deleteKid_shouldReturnNotFoundWhenNotDeleted() {
        when(certificateService.deleteCertByClientIdAndKId("client1", "kid1"))
                .thenReturn(false);

        ResponseEntity<?> response =
                certificateController.deleteKID("client1", "kid1");

        assertEquals(HttpStatus.NOT_FOUND, response.getStatusCode());
        assertTrue(response.getBody().toString().contains("Certificate not found"));
        assertTrue(response.getBody().toString().contains("client1"));

        verify(certificateService).deleteCertByClientIdAndKId("client1", "kid1");
    }

    @Test
    void getCertificates_shouldReturnCertificateList() {
        CertSearchRequest request = new CertSearchRequest();

        List<CertResponse> certResponses = List.of(
                new CertResponse(),
                new CertResponse()
        );

        when(certificateService.getCertificates(request))
                .thenReturn(certResponses);

        ResponseEntity<List<CertResponse>> response =
                certificateController.getCertificates(request);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertEquals(2, response.getBody().size());

        verify(certificateService).getCertificates(request);
    }

    @Test
    void getCertificates_shouldReturnEmptyList() {
        CertSearchRequest request = new CertSearchRequest();

        when(certificateService.getCertificates(request))
                .thenReturn(Collections.emptyList());

        ResponseEntity<List<CertResponse>> response =
                certificateController.getCertificates(request);

        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertNotNull(response.getBody());
        assertTrue(response.getBody().isEmpty());

        verify(certificateService).getCertificates(request);
    }
}
