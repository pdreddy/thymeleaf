import lombok.extern.slf4j.Slf4j;
import org.springframework.core.io.Resource;
import org.springframework.core.io.ResourceLoader;
import org.springframework.stereotype.Service;

import jakarta.annotation.PostConstruct;
import java.io.ByteArrayInputStream;
import java.io.FileNotFoundException;
import java.io.InputStream;
import java.nio.charset.StandardCharsets;
import java.security.cert.*;
import java.util.*;

@Slf4j
@Service
public class CertValidatorService {

    private final ResourceLoader resourceLoader;

    private List<X509Certificate> rootCerts;
    private List<X509Certificate> intermediateCerts;
    private Set<TrustAnchor> trustAnchors;

    public CertValidatorService(ResourceLoader resourceLoader) {
        this.resourceLoader = resourceLoader;
    }

    @PostConstruct
    public void init() throws Exception {
        log.info("========== CertValidatorService init BEGIN ==========");

        List<X509Certificate> allCerts =
                loadCertificatesFromResource("classpath:certs/root-cert.pem");

        this.rootCerts = new ArrayList<>();
        this.intermediateCerts = new ArrayList<>();
        this.trustAnchors = new HashSet<>();

        for (X509Certificate cert : allCerts) {
            logCert("CA", cert);

            if (isSelfSigned(cert)) {
                rootCerts.add(cert);
                trustAnchors.add(new TrustAnchor(cert, null));
                log.info("Added as ROOT TrustAnchor");
            } else {
                intermediateCerts.add(cert);
                log.info("Added as INTERMEDIATE CertStore cert");
            }
        }

        log.info("Root cert count         : {}", rootCerts.size());
        log.info("Intermediate cert count : {}", intermediateCerts.size());
        log.info("TrustAnchor count       : {}", trustAnchors.size());

        if (trustAnchors.isEmpty()) {
            throw new IllegalStateException("No root/self-signed certificate found in root-cert.pem");
        }

        log.info("========== CertValidatorService init END ==========");
    }

    public X509Certificate validateCertificateFromText(String publicCertText) throws Exception {
        log.info("========== validateCertificateFromText BEGIN ==========");

        X509Certificate leafCert = loadCertificateFromText(publicCertText);
        logCert("LEAF", leafCert);

        log.info("Leaf Issuer: {}", leafCert.getIssuerX500Principal());

        for (X509Certificate intermediate : intermediateCerts) {
            log.info("Intermediate Subject: {}", intermediate.getSubjectX500Principal());
            log.info("Leaf issuer matches intermediate subject? {}",
                    leafCert.getIssuerX500Principal().equals(intermediate.getSubjectX500Principal()));
        }

        for (X509Certificate root : rootCerts) {
            log.info("Root Subject: {}", root.getSubjectX500Principal());
            log.info("Leaf issuer matches root subject? {}",
                    leafCert.getIssuerX500Principal().equals(root.getSubjectX500Principal()));
        }

        X509CertSelector selector = new X509CertSelector();
        selector.setCertificate(leafCert);

        PKIXBuilderParameters params =
                new PKIXBuilderParameters(trustAnchors, selector);

        params.setRevocationEnabled(false);

        List<X509Certificate> certStoreCerts = new ArrayList<>();
        certStoreCerts.add(leafCert);
        certStoreCerts.addAll(intermediateCerts);

        CertStore certStore = CertStore.getInstance(
                "Collection",
                new CollectionCertStoreParameters(certStoreCerts)
        );

        params.addCertStore(certStore);

        log.info("CertStore count: {}", certStoreCerts.size());
        log.info("Starting PKIX path builder...");

        try {
            CertPathBuilder builder = CertPathBuilder.getInstance("PKIX");

            PKIXCertPathBuilderResult result =
                    (PKIXCertPathBuilderResult) builder.build(params);

            log.info("========== Chain validated successfully ==========");
            log.info("Trusted Root: {}",
                    result.getTrustAnchor().getTrustedCert().getSubjectX500Principal());

            List<? extends Certificate> pathCerts =
                    result.getCertPath().getCertificates();

            log.info("Built chain size: {}", pathCerts.size());

            for (int i = 0; i < pathCerts.size(); i++) {
                logCert("CHAIN-" + i, (X509Certificate) pathCerts.get(i));
            }

            return leafCert;

        } catch (CertPathBuilderException ex) {
            log.error("PKIX path build failed: {}", ex.getMessage());
            log.error("Leaf Subject: {}", leafCert.getSubjectX500Principal());
            log.error("Leaf Issuer : {}", leafCert.getIssuerX500Principal());
            log.error("Root count: {}", rootCerts.size());
            log.error("Intermediate count: {}", intermediateCerts.size());

            for (X509Certificate root : rootCerts) {
                log.error("ROOT Subject: {}", root.getSubjectX500Principal());
                log.error("ROOT Issuer : {}", root.getIssuerX500Principal());
            }

            for (X509Certificate intermediate : intermediateCerts) {
                log.error("INTERMEDIATE Subject: {}", intermediate.getSubjectX500Principal());
                log.error("INTERMEDIATE Issuer : {}", intermediate.getIssuerX500Principal());
            }

            throw ex;
        }
    }

    private List<X509Certificate> loadCertificatesFromResource(String resourcePath) throws Exception {
        log.info("Loading certs from resource: {}", resourcePath);

        Resource resource = resourceLoader.getResource(resourcePath);

        log.info("Resource exists: {}", resource.exists());

        try {
            log.info("Resource URI: {}", resource.getURI());
        } catch (Exception e) {
            log.warn("Unable to read resource URI: {}", e.getMessage());
        }

        if (!resource.exists()) {
            throw new FileNotFoundException("Resource not found: " + resourcePath);
        }

        CertificateFactory cf = CertificateFactory.getInstance("X.509");
        List<X509Certificate> certs = new ArrayList<>();

        try (InputStream is = resource.getInputStream()) {
            Collection<? extends Certificate> collection =
                    cf.generateCertificates(is);

            if (collection == null || collection.isEmpty()) {
                throw new IllegalArgumentException("No certificates found in: " + resourcePath);
            }

            for (Certificate cert : collection) {
                certs.add((X509Certificate) cert);
            }
        }

        log.info("Loaded certificate count from {}: {}", resourcePath, certs.size());
        return certs;
    }

    private X509Certificate loadCertificateFromText(String certText) throws Exception {
        String normalizedPem = normalizePem(certText);

        CertificateFactory cf = CertificateFactory.getInstance("X.509");

        try (InputStream is = new ByteArrayInputStream(
                normalizedPem.getBytes(StandardCharsets.UTF_8))) {

            X509Certificate cert = (X509Certificate) cf.generateCertificate(is);
            cert.checkValidity();
            return cert;
        }
    }

    private String normalizePem(String certText) {
        if (certText == null || certText.trim().isEmpty()) {
            throw new IllegalArgumentException("Certificate text is empty");
        }

        String clean = certText
                .replace("-----BEGIN CERTIFICATE-----", "")
                .replace("-----END CERTIFICATE-----", "")
                .replaceAll("\\s+", "");

        return "-----BEGIN CERTIFICATE-----\n"
                + clean.replaceAll("(.{64})", "$1\n")
                + "\n-----END CERTIFICATE-----";
    }

    private boolean isSelfSigned(X509Certificate cert) {
        return cert.getSubjectX500Principal()
                .equals(cert.getIssuerX500Principal());
    }

    private void logCert(String label, X509Certificate cert) {
        log.info("{} Subject : {}", label, cert.getSubjectX500Principal());
        log.info("{} Issuer  : {}", label, cert.getIssuerX500Principal());
        log.info("{} Serial  : {}", label, cert.getSerialNumber());
        log.info("{} ValidFrom: {}", label, cert.getNotBefore());
        log.info("{} ValidTo  : {}", label, cert.getNotAfter());
    }
}
