@Test
    void deleteCertByClientIdAndKId_shouldReturnTrueAndDeleteCacheWhenRecordDeleted() {
        when(certificateRepository.deleteByClientIdAndJwtId("client1", "kid1"))
                .thenReturn(1L);

        boolean result = certificateService.deleteCertByClientIdAndKId("client1", "kid1");

        assertTrue(result);

        verify(certificateRepository).deleteByClientIdAndJwtId("client1", "kid1");
        verify(redisTemplate).delete("CERT_CLIENT_client1"); // update key if your actual prefix differs
    }

    @Test
    void deleteCertByClientIdAndKId_shouldReturnFalseWhenNoRecordDeleted() {
        when(certificateRepository.deleteByClientIdAndJwtId("client1", "kid1"))
                .thenReturn(0L);

        boolean result = certificateService.deleteCertByClientIdAndKId("client1", "kid1");

        assertFalse(result);

        verify(certificateRepository).deleteByClientIdAndJwtId("client1", "kid1");
        verify(redisTemplate, never()).delete(anyString());
    }

    @Test
    void getCertificates_shouldReturnMappedCertResponses() {
        CertSearchRequest request = new CertSearchRequest();

        Certificate cert1 = new Certificate();
        cert1.setClientId("client1");
        cert1.setJwtId("kid1");
        cert1.setCertSerialNumber("SER123");
        cert1.setCertBeginDate(LocalDateTime.now().minusDays(1));
        cert1.setCertEndDate(LocalDateTime.now().plusDays(10));
        cert1.setAddedBy("testuser");

        Certificate cert2 = new Certificate();
        cert2.setClientId("client2");
        cert2.setJwtId("kid2");
        cert2.setCertSerialNumber("SER456");
        cert2.setCertBeginDate(LocalDateTime.now().minusDays(2));
        cert2.setCertEndDate(LocalDateTime.now().plusDays(20));
        cert2.setAddedBy("admin");

        when(certificateRepository.findAll(
                any(Specification.class),
                any(Sort.class)
        )).thenReturn(List.of(cert1, cert2));

        List<CertResponse> result = certificateService.getCertificates(request);

        assertNotNull(result);
        assertEquals(2, result.size());

        verify(certificateRepository).findAll(
                any(Specification.class),
                argThat(sort -> sort.getOrderFor("certBeginDate") != null)
        );
    }

    @Test
    void getCertificates_shouldReturnEmptyListWhenRepositoryEmpty() {
        CertSearchRequest request = new CertSearchRequest();

        when(certificateRepository.findAll(
                any(Specification.class),
                any(Sort.class)
        )).thenReturn(Collections.emptyList());

        List<CertResponse> result = certificateService.getCertificates(request);

        assertNotNull(result);
        assertTrue(result.isEmpty());

        verify(certificateRepository).findAll(
                any(Specification.class),
                any(Sort.class)
        );
    }

    @Test
    void getActiveCertCount_shouldReturnRepositoryCount() {
        when(certificateRepository.countActiveCertificates("client1"))
                .thenReturn(2L);

        long result = certificateService.getActiveCertCount("client1");

        assertEquals(2L, result);

        verify(certificateRepository).countActiveCertificates("client1");
    }
