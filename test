    @Test
    void shouldBuildJustificationLikePredicate_whenJustificationPresent() {
        CertSearchRequest req = new CertSearchRequest();
        req.setJustification("Test Value");

        Root<Certificate> root = mock(Root.class);
        CriteriaQuery<?> query = mock(CriteriaQuery.class);
        CriteriaBuilder cb = mock(CriteriaBuilder.class);

        Path<byte[]> justificationPath = mock(Path.class);
        Expression<String> utf8Expression = mock(Expression.class);
        Expression<String> justificationText = mock(Expression.class);
        Expression<String> lowerJustificationText = mock(Expression.class);

        Predicate likePredicate = mock(Predicate.class);
        Predicate finalPredicate = mock(Predicate.class);

        when(root.<byte[]>get("justification")).thenReturn(justificationPath);
        when(cb.literal("UTF8")).thenReturn(utf8Expression);

        when(cb.function(
                eq("convert_from"),
                eq(String.class),
                eq(justificationPath),
                eq(utf8Expression)
        )).thenReturn(justificationText);

        when(cb.lower(justificationText)).thenReturn(lowerJustificationText);

        when(cb.like(eq(lowerJustificationText), eq("%test value%")))
                .thenReturn(likePredicate);

        when(cb.and(any(Predicate[].class))).thenReturn(finalPredicate);

        Predicate result = CertificateSpecification.filter(req)
                .toPredicate(root, query, cb);

        assertNotNull(result);
        assertSame(finalPredicate, result);

        verify(cb).function(
                eq("convert_from"),
                eq(String.class),
                eq(justificationPath),
                eq(utf8Expression)
        );

        verify(cb).lower(justificationText);
        verify(cb).like(lowerJustificationText, "%test value%");
        verify(cb).and(any(Predicate[].class));
    }

