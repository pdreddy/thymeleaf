@Slf4j
@Service
public class CertValidatorService {

    private static final String ROOT_CERT_PATH = "classpath:certs/root-cert.pem";
    private static final String AIA_OID = "1.3.6.1.5.5.7.1.1";

    private final ResourceLoader resourceLoader;
    private Set<TrustAnchor> trustAnchors;
    private final Map<String, X509Certificate> intermediateCache = new ConcurrentHashMap<>();

    public CertValidatorService(ResourceLoader resourceLoader) {
        this.resourceLoader = resourceLoader;
    }

    @PostConstruct
    public void init() {
        log.info("Initializing CertValidatorService");
        log.info("Java version: {}", System.getProperty("java.version"));
        log.info("Java home: {}", System.getProperty("java.home"));

        this.trustAnchors = loadRootTrustAnchors(ROOT_CERT_PATH);

        log.info("CertValidatorService initialized successfully. Trust anchors count={}", trustAnchors.size());
    }

    public void validateCertificateFromText(String incomingCertText) {
        try {
            log.info("Starting certificate validation from incoming text");

            X509Certificate leafCert = parseSingleCertificate(incomingCertText);
            logCert("LEAF", leafCert);

            X509Certificate intermediateCert = fetchIntermediateFromAia(leafCert);
            logCert("INTERMEDIATE_FROM_AIA", intermediateCert);

            validateChain(leafCert, intermediateCert);

            log.info("Certificate validation SUCCESS");

        } catch (Exception e) {
            log.error("Certificate validation FAILED", e);
            throw new IllegalArgumentException(
                    "Certificate chain validation failed. Intermediate certificate may be missing or AIA download failed.",
                    e
            );
        }
    }

    private Set<TrustAnchor> loadRootTrustAnchors(String location) {
        try {
            log.info("Loading root certificate from {}", location);

            Resource resource = resourceLoader.getResource(location);

            log.info("Root resource exists: {}", resource.exists());
            log.info("Root resource readable: {}", resource.isReadable());

            if (!resource.exists()) {
                throw new IllegalStateException("Root certificate not found at " + location);
            }

            try (InputStream is = resource.getInputStream()) {
                CertificateFactory cf = CertificateFactory.getInstance("X.509");
                Collection<? extends Certificate> certs = cf.generateCertificates(is);

                if (certs.isEmpty()) {
                    throw new IllegalStateException("No root certificates found in " + location);
                }

                Set<TrustAnchor> anchors = new HashSet<>();

                for (Certificate cert : certs) {
                    X509Certificate root = (X509Certificate) cert;
                    root.checkValidity();

                    logCert("ROOT", root);

                    anchors.add(new TrustAnchor(root, null));
                }

                return anchors;
            }

        } catch (Exception e) {
            throw new IllegalStateException("Failed to load root certificate from " + location, e);
        }
    }

    private X509Certificate parseSingleCertificate(String certText) {
        try {
            if (certText == null || certText.trim().isEmpty()) {
                throw new IllegalArgumentException("Incoming certificate text is empty");
            }

            String normalized = normalizeToPem(certText);

            log.info("Incoming cert text normalized. Length={}", normalized.length());

            CertificateFactory cf = CertificateFactory.getInstance("X.509");

            try (InputStream is = new ByteArrayInputStream(normalized.getBytes(StandardCharsets.UTF_8))) {
                Collection<? extends Certificate> certs = cf.generateCertificates(is);

                log.info("Incoming certificates parsed count={}", certs.size());

                if (certs.isEmpty()) {
                    throw new IllegalArgumentException("No certificate parsed from incoming text");
                }

                X509Certificate cert = (X509Certificate) certs.iterator().next();
                cert.checkValidity();

                return cert;
            }

        } catch (Exception e) {
            throw new IllegalArgumentException("Unable to parse incoming certificate text", e);
        }
    }

    private String normalizeToPem(String certText) {
        String text = certText.trim();

        if (text.contains("-----BEGIN CERTIFICATE-----")) {
            return text;
        }

        String cleaned = text
                .replaceAll("\\s+", "")
                .replace("-----BEGINCERTIFICATE-----", "")
                .replace("-----ENDCERTIFICATE-----", "");

        StringBuilder pem = new StringBuilder();
        pem.append("-----BEGIN CERTIFICATE-----\n");

        for (int i = 0; i < cleaned.length(); i += 64) {
            pem.append(cleaned, i, Math.min(i + 64, cleaned.length()));
            pem.append("\n");
        }

        pem.append("-----END CERTIFICATE-----\n");

        return pem.toString();
    }

    private X509Certificate fetchIntermediateFromAia(X509Certificate leafCert) {
        List<String> urls = extractAiaCaIssuerUrls(leafCert);

        if (urls.isEmpty()) {
            throw new IllegalArgumentException("No AIA CA Issuers URL found in leaf certificate");
        }

        for (String url : urls) {
            try {
                log.info("Trying AIA intermediate URL: {}", url);

                X509Certificate cert = intermediateCache.computeIfAbsent(url, this::downloadCertificate);

                log.info("Intermediate downloaded/cached successfully from {}", url);

                return cert;

            } catch (Exception e) {
                log.warn("Failed to download intermediate from AIA URL: {}", url, e);
            }
        }

        throw new IllegalArgumentException("Unable to download intermediate certificate from all AIA URLs");
    }

    private List<String> extractAiaCaIssuerUrls(X509Certificate cert) {
        try {
            byte[] extValue = cert.getExtensionValue(AIA_OID);

            log.info("AIA extension present: {}", extValue != null);

            if (extValue == null) {
                return Collections.emptyList();
            }

            ASN1Primitive primitive = JcaX509ExtensionUtils.parseExtensionValue(extValue);
            AuthorityInformationAccess aia = AuthorityInformationAccess.getInstance(primitive);

            List<String> urls = new ArrayList<>();

            for (AccessDescription accessDescription : aia.getAccessDescriptions()) {
                log.info("AIA access method: {}", accessDescription.getAccessMethod());

                if (AccessDescription.id_ad_caIssuers.equals(accessDescription.getAccessMethod())) {
                    GeneralName location = accessDescription.getAccessLocation();

                    log.info("AIA location tag: {}", location.getTagNo());

                    if (location.getTagNo() == GeneralName.uniformResourceIdentifier) {
                        String url = DERIA5String.getInstance(location.getName()).getString();
                        log.info("AIA CA Issuers URL found: {}", url);
                        urls.add(url);
                    }
                }
            }

            log.info("Total AIA CA Issuers URLs found: {}", urls.size());

            return urls;

        } catch (Exception e) {
            throw new IllegalArgumentException("Failed to extract AIA URL from leaf certificate", e);
        }
    }

    private X509Certificate downloadCertificate(String urlText) {
        HttpURLConnection connection = null;

        try {
            log.info("Downloading intermediate certificate from {}", urlText);

            URL url = new URL(urlText);
            connection = (HttpURLConnection) url.openConnection();

            connection.setConnectTimeout(5000);
            connection.setReadTimeout(5000);
            connection.setInstanceFollowRedirects(true);
            connection.setRequestMethod("GET");

            int status = connection.getResponseCode();
            log.info("AIA HTTP response status: {}", status);

            if (status < 200 || status >= 300) {
                throw new IllegalArgumentException("AIA URL returned non-success status: " + status);
            }

            try (InputStream is = connection.getInputStream()) {
                CertificateFactory cf = CertificateFactory.getInstance("X.509");
                X509Certificate cert = (X509Certificate) cf.generateCertificate(is);
                cert.checkValidity();

                return cert;
            }

        } catch (Exception e) {
            throw new IllegalArgumentException("Failed to download certificate from URL: " + urlText, e);

        } finally {
            if (connection != null) {
                connection.disconnect();
            }
        }
    }

    private void validateChain(X509Certificate leafCert, X509Certificate intermediateCert) {
        try {
            log.info("Validating certificate chain: Leaf -> Intermediate -> Root");

            log.info("Leaf Issuer        : {}", leafCert.getIssuerX500Principal());
            log.info("Intermediate Subject: {}", intermediateCert.getSubjectX500Principal());
            log.info("Intermediate Issuer : {}", intermediateCert.getIssuerX500Principal());

            boolean leafMatchesIntermediate =
                    leafCert.getIssuerX500Principal().equals(intermediateCert.getSubjectX500Principal());

            log.info("Leaf issuer matches intermediate subject: {}", leafMatchesIntermediate);

            if (!leafMatchesIntermediate) {
                throw new IllegalArgumentException("Leaf issuer does not match intermediate subject");
            }

            List<X509Certificate> chain = List.of(leafCert, intermediateCert);

            CertificateFactory cf = CertificateFactory.getInstance("X.509");
            CertPath certPath = cf.generateCertPath(chain);

            PKIXParameters params = new PKIXParameters(trustAnchors);
            params.setRevocationEnabled(false);

            CertPathValidator validator = CertPathValidator.getInstance("PKIX");

            log.info("Calling PKIX validator");

            validator.validate(certPath, params);

            log.info("PKIX validation passed");

        } catch (CertPathValidatorException e) {
            log.error("PKIX failed at certificate index: {}", e.getIndex());
            log.error("PKIX failure reason: {}", e.getReason());
            throw new IllegalArgumentException("PKIX validation failed: " + e.getMessage(), e);

        } catch (Exception e) {
            throw new IllegalArgumentException("Certificate chain validation failed", e);
        }
    }

    private void logCert(String label, X509Certificate cert) {
        log.info("{} Subject   : {}", label, cert.getSubjectX500Principal());
        log.info("{} Issuer    : {}", label, cert.getIssuerX500Principal());
        log.info("{} Serial    : {}", label, cert.getSerialNumber());
        log.info("{} Valid From: {}", label, cert.getNotBefore());
        log.info("{} Valid To  : {}", label, cert.getNotAfter());
        log.info("{} SigAlg    : {}", label, cert.getSigAlgName());
    }
}


